# Claude memory & per-machine state
.claude/settings.local.json
.claude/worktrees/
.claude/scheduled_tasks.lock

# Local-only drafts (project-specific; subprojects can also have their own)
/community-posts/

# Logs at repo root only
/*.log

# OS
.DS_Store
Thumbs.db

# Leftover build artifacts/caches at repo root from pre-reorganization layout.
# Anchored with a leading slash so they only match at the monorepo root —
# subprojects (e.g. tarkov-price-overlay/src-tauri/) have their own .gitignore
# that controls their build artifacts.
/node_modules/
/dist/
/dist-python/
/build-python/
/python-core/
/src-tauri/
